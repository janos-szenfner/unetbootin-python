[Desktop Entry]
Version=1.0.1
Type=Application
Name=UNetbootin
GenericName=Bootable USB Creator
Comment=Create bootable USB drives from ISO files
Exec=unetbootin %F
Icon=unetbootin
Terminal=false
Categories=System;Filesystem;Utility;
StartupNotify=true
StartupWMClass=unetbootin
MimeType=application/x-iso;application/x-cd-image;
Keywords=usb;boot;iso;install;live;
